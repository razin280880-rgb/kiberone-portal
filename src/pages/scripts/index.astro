---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SCRIPTS, SCRIPT_CATEGORIES } from '@/data/scripts';

const grouped = SCRIPTS.reduce<Record<string, typeof SCRIPTS>>((acc, s) => {
  (acc[s.category] ||= []).push(s);
  return acc;
}, {});
const order: Array<keyof typeof SCRIPT_CATEGORIES> = [
  'soprovozhdenie', 'prodlenie', 'probnyj', 'reanimaciya', 'letnij',
  'shkoly', 'dokumenty', 'shablony',
];
---
<BaseLayout title="Скрипты" description="Скрипты звонков, WhatsApp-шаблоны и шпаргалки KIBERone.">
  <section class="bg-kiber-dark text-white">
    <div class="container-page py-12 md:py-16">
      <a href="/" class="text-sm text-kiber-lime/80 hover:text-kiber-lime">← На главную</a>
      <h1 class="font-display text-3xl md:text-5xl font-extrabold mt-3">Скрипты</h1>
      <p class="mt-3 text-white/80 max-w-2xl">
        Все скрипты звонков и WhatsApp-шаблоны: сопровождение, продление, реанимация ушедших, летние программы, банк возражений.
      </p>
    </div>
  </section>

  <section class="container-page py-12 space-y-12">
    {order.map((cat) => {
      const list = grouped[cat] || [];
      if (!list.length) return null;
      const meta = SCRIPT_CATEGORIES[cat];
      return (
        <div>
          <h2 class="font-display text-xl md:text-2xl font-bold text-kiber-dark mb-4 flex items-center gap-2">
            <span>{meta.icon}</span> {meta.label}
          </h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {list.map((s) => (
              <a href={`/scripts/${s.slug}/`} class="card p-5 hover:-translate-y-0.5 transition flex flex-col">
                <div class="font-semibold text-kiber-dark">{s.title}</div>
                <p class="text-sm text-kiber-ink/80 mt-2 flex-1">{s.short}</p>
                <span class="mt-3 text-sm font-semibold text-kiber-blue">Открыть →</span>
              </a>
            ))}
          </div>
        </div>
      );
    })}
  </section>
</BaseLayout>
