---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Поиск" description="Поиск по всему порталу: должности, регламенты, скрипты.">
  <section class="bg-kiber-dark text-white">
    <div class="container-page py-10 md:py-14">
      <a href="/" class="text-sm text-kiber-lime/80 hover:text-kiber-lime">← На главную</a>
      <h1 class="font-display text-3xl md:text-5xl font-extrabold mt-3">Поиск по порталу</h1>
      <p class="mt-3 text-white/80 max-w-2xl">
        Найди должность, регламент, скрипт или конкретный пункт чек-листа. Поиск ищет по всему контенту портала.
      </p>
    </div>
  </section>

  <section class="container-page py-10" data-pagefind-ignore>
    <div id="search" class="card p-4 md:p-6"></div>
    <p class="mt-4 text-sm text-kiber-muted">
      Подсказки: ищи по фамилии должности («тьютор», «фермер»), по теме («продление», «пропуски», «ярмарка»),
      по типу документа («регламент», «скрипт», «чек-лист»). Поиск работает на русском с учётом окончаний.
    </p>
    <div id="search-fallback" class="hidden mt-6 card p-5 ring-1 ring-amber-400/40 bg-amber-50">
      <div class="font-semibold text-amber-900">Поисковый индекс ещё не построен</div>
      <p class="text-sm text-amber-900/80 mt-1">
        Запусти <code class="px-1.5 py-0.5 rounded bg-amber-100">npm run build</code>, чтобы создать индекс, и открой портал через <code class="px-1.5 py-0.5 rounded bg-amber-100">npm run preview</code>.
        В dev-режиме поиск не работает — это особенность Pagefind.
      </p>
    </div>
  </section>

  <link
    rel="stylesheet"
    href="/pagefind/pagefind-ui.css"
    onerror="document.getElementById('search-fallback')?.classList.remove('hidden')"
  />

  <script is:inline>
    // Pagefind UI — loaded as ES module at runtime, only after the index has been built.
    (async function initSearch() {
      try {
        const mod = await import('/pagefind/pagefind-ui.js');
        new mod.PagefindUI({
          element: '#search',
          showImages: false,
          showSubResults: true,
          resetStyles: false,
          translations: {
            placeholder: 'Найти по порталу…',
            clear_search: 'Очистить',
            load_more: 'Показать ещё',
            search_label: 'Поиск',
            filters_label: 'Фильтры',
            zero_results: 'Ничего не найдено для запроса [SEARCH_TERM]',
            many_results: 'Найдено [COUNT] результатов по запросу [SEARCH_TERM]',
            one_result: 'Найден 1 результат по запросу [SEARCH_TERM]',
            alt_search: 'Ничего не найдено для [SEARCH_TERM]. Показываем результаты для [DIFFERENT_TERM].',
            search_suggestion: 'Ничего не найдено для [SEARCH_TERM]. Попробуй один из вариантов:',
            searching: 'Поиск по [SEARCH_TERM]…',
          },
        });
      } catch (err) {
        const fallback = document.getElementById('search-fallback');
        if (fallback) fallback.classList.remove('hidden');
        console.warn('Pagefind index not available:', err);
      }
    })();
  </script>

  <style is:global>
    :root {
      --pagefind-ui-scale: 1;
      --pagefind-ui-primary: #0B1530;
      --pagefind-ui-text: #1A1F36;
      --pagefind-ui-background: #ffffff;
      --pagefind-ui-border: rgba(11, 21, 48, 0.12);
      --pagefind-ui-tag: rgba(11, 21, 48, 0.05);
      --pagefind-ui-border-width: 1px;
      --pagefind-ui-border-radius: 12px;
      --pagefind-ui-image-border-radius: 8px;
      --pagefind-ui-font: 'Inter', system-ui, sans-serif;
    }
    .pagefind-ui__search-input {
      font-weight: 500;
    }
    .pagefind-ui__result-title a {
      color: #0B1530;
    }
    .pagefind-ui__result-link {
      color: #1E40AF;
    }
  </style>
</BaseLayout>
