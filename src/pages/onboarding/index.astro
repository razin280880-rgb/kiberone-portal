---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { POSITIONS } from '@/data/positions';

const featured = ['tutor', 'assistent', 'fermer', 'hanter', 'rukovoditel-filiala', 'metodist'];
const featuredPositions = featured
  .map((slug) => POSITIONS.find((p) => p.slug === slug)!)
  .filter(Boolean);
const otherPositions = POSITIONS.filter((p) => !featured.includes(p.slug));
---
<BaseLayout title="Я новый сотрудник" description="Пошаговый онбординг в KIBERone: что прочитать, что сделать, к кому обратиться.">
  <section class="bg-gradient-to-br from-kiber-dark via-kiber-deep to-kiber-dark text-white">
    <div class="container-page py-12 md:py-16">
      <a href="/" class="text-sm text-kiber-lime/80 hover:text-kiber-lime">← На главную</a>
      <h1 class="font-display text-3xl md:text-5xl font-extrabold mt-3">
        Добро пожаловать в <span class="text-kiber-lime">KIBERone</span>
      </h1>
      <p class="mt-4 text-white/85 max-w-2xl text-lg">
        Если ты только устроился — этот раздел поможет влиться. Здесь маршрут на первую неделю и первый месяц: что прочитать, что сделать, к кому обратиться.
      </p>
    </div>
  </section>

  <!-- 3 questions -->
  <section class="container-page py-12">
    <h2 class="font-display text-2xl md:text-3xl font-bold text-kiber-dark mb-2">Сначала 3 вопроса, чтобы не запутаться</h2>
    <p class="text-kiber-muted mb-6">Прочитай по порядку — это даст общую картину компании.</p>
    <div class="grid md:grid-cols-3 gap-4">
      <div class="card p-6">
        <div class="text-3xl mb-3">🏗️</div>
        <h3 class="font-display text-lg font-bold text-kiber-dark">1. Где я работаю</h3>
        <ul class="mt-3 space-y-1.5 text-sm text-kiber-ink/85 list-disc list-inside">
          <li>KIBERone — школа программирования для детей 6-14 лет</li>
          <li>Сеть из 7 филиалов: Челны, Казань, Нижнекамск, Елабуга, Краснодар, Сургут, Пермь</li>
          <li>Франчайзи федеральной сети — наш владелец отвечает за всю сеть</li>
        </ul>
      </div>
      <div class="card p-6">
        <div class="text-3xl mb-3">🧭</div>
        <h3 class="font-display text-lg font-bold text-kiber-dark">2. Как устроены команды</h3>
        <ul class="mt-3 space-y-1.5 text-sm text-kiber-ink/85 list-disc list-inside">
          <li>В филиале: РФ, тьюторы, ассистенты, офис-менеджер, менеджер развития</li>
          <li>Центрально (на всю сеть): методист, отделы продаж, сопровождения, HR, маркетинг</li>
          <li>Каждый сотрудник подчиняется и локально (РФ), и функционально (своему отделу)</li>
        </ul>
      </div>
      <div class="card p-6">
        <div class="text-3xl mb-3">🌀</div>
        <h3 class="font-display text-lg font-bold text-kiber-dark">3. Как ребёнок проходит путь</h3>
        <ul class="mt-3 space-y-1.5 text-sm text-kiber-ink/85 list-disc list-inside">
          <li><b>Менеджер развития</b> приводит лидов</li>
          <li><b>Хантер</b> продаёт пробный → продаёт абонемент</li>
          <li><b>Тьютор + ассистент</b> ведут уроки</li>
          <li><b>Фермер</b> удерживает, продлевает, допродаёт</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Choose role -->
  <section class="container-page pb-12">
    <h2 class="font-display text-2xl md:text-3xl font-bold text-kiber-dark mb-2">Открой свою должность</h2>
    <p class="text-kiber-muted mb-6">Внутри каждой роли — отдельный раздел <b>«Адаптация (новичкам)»</b> с пошаговым планом.</p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {featuredPositions.map((p) => (
        <a href={`/positions/${p.slug}/adaptaciya/`} class="card p-5 hover:-translate-y-0.5 transition flex flex-col">
          <div class="flex items-center gap-3">
            <div class="w-11 h-11 rounded-xl bg-kiber-lime/30 grid place-items-center text-xl">{p.icon}</div>
            <div>
              <div class="font-semibold text-kiber-dark">{p.title}</div>
              <div class="text-xs text-kiber-muted">{p.dept}</div>
            </div>
          </div>
          <p class="mt-3 text-sm text-kiber-ink/80 flex-1">{p.short}</p>
          <span class="mt-3 text-sm font-semibold text-kiber-blue">Открыть план адаптации →</span>
        </a>
      ))}
    </div>

    <details class="mt-6 card p-5">
      <summary class="cursor-pointer font-semibold text-kiber-dark">Другие должности ({otherPositions.length})</summary>
      <div class="mt-4 grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {otherPositions.map((p) => (
          <a href={`/positions/${p.slug}/adaptaciya/`} class="rounded-xl ring-1 ring-kiber-dark/10 p-3 flex items-center gap-3 hover:bg-kiber-dark/5 transition">
            <div class="text-xl">{p.icon}</div>
            <div class="min-w-0">
              <div class="font-medium text-sm text-kiber-dark truncate">{p.title}</div>
              <div class="text-[11px] text-kiber-muted truncate">{p.dept}</div>
            </div>
          </a>
        ))}
      </div>
    </details>
  </section>

  <!-- First week / first month -->
  <section class="container-page pb-16">
    <h2 class="font-display text-2xl md:text-3xl font-bold text-kiber-dark mb-2">Универсальная карта первой недели</h2>
    <p class="text-kiber-muted mb-6">Работает для любой должности — детали смотри в своей роли.</p>
    <div class="grid md:grid-cols-3 gap-4">
      <div class="card p-6">
        <div class="chip">День 1</div>
        <h3 class="font-display text-lg font-bold text-kiber-dark mt-3">Знакомство</h3>
        <ul class="mt-3 space-y-1.5 text-sm text-kiber-ink/85 list-disc list-inside">
          <li>Встреча с руководителем филиала (РФ)</li>
          <li>Экскурсия по филиалу, знакомство с командой</li>
          <li>Доступы: чат филиала, CRM, Google Drive</li>
          <li>Прочитать <a class="text-kiber-blue font-medium" href="/positions/">страницу своей должности</a></li>
        </ul>
      </div>
      <div class="card p-6">
        <div class="chip">Неделя 1</div>
        <h3 class="font-display text-lg font-bold text-kiber-dark mt-3">Погружение</h3>
        <ul class="mt-3 space-y-1.5 text-sm text-kiber-ink/85 list-disc list-inside">
          <li>Прочитать раздел «Адаптация» в своей должности</li>
          <li>Прочитать чек-листы и снимок рабочего дня</li>
          <li>Наблюдать за коллегой / наставником минимум 2 раза</li>
          <li>Изучить регламенты, относящиеся к должности</li>
        </ul>
      </div>
      <div class="card p-6">
        <div class="chip">Месяц 1</div>
        <h3 class="font-display text-lg font-bold text-kiber-dark mt-3">Самостоятельность</h3>
        <ul class="mt-3 space-y-1.5 text-sm text-kiber-ink/85 list-disc list-inside">
          <li>Самостоятельные задачи под контролем наставника</li>
          <li>Знать KPI своей роли и где их смотреть</li>
          <li>Знать всех ключевых коллег по сети (методист, РОП, РОС, HR)</li>
          <li>Аттестация / собеседование с РФ по итогам месяца</li>
        </ul>
      </div>
    </div>

    <div class="mt-10 card p-6 md:p-8 bg-kiber-dark text-white">
      <h3 class="font-display text-xl font-bold">Если что-то непонятно</h3>
      <div class="grid md:grid-cols-3 gap-4 mt-4 text-sm">
        <div>
          <div class="text-kiber-lime font-semibold mb-1">По работе в филиале</div>
          <div class="text-white/85">Руководитель филиала (РФ) — твой основной контакт.</div>
        </div>
        <div>
          <div class="text-kiber-lime font-semibold mb-1">По методике / урокам</div>
          <div class="text-white/85">Методист сети + старший тьютор филиала.</div>
        </div>
        <div>
          <div class="text-kiber-lime font-semibold mb-1">По договору / зарплате</div>
          <div class="text-white/85">HR-специалист сети.</div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
