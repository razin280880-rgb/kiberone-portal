---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { POSITIONS } from '@/data/positions';

const grouped = POSITIONS.reduce<Record<string, typeof POSITIONS>>((acc, p) => {
  (acc[p.dept] ||= []).push(p);
  return acc;
}, {});
const departments = Object.keys(grouped);
---
<BaseLayout title="Должности" description="Все должности KIBERone: тьютор, ассистент, методист, РФ, фермер, хантер и другие.">
  <section class="bg-kiber-dark text-white">
    <div class="container-page py-12 md:py-16">
      <a href="/" class="text-sm text-kiber-lime/80 hover:text-kiber-lime">← На главную</a>
      <h1 class="font-display text-3xl md:text-5xl font-extrabold mt-3">Должности</h1>
      <p class="mt-3 text-white/80 max-w-2xl">
        {POSITIONS.length} ролей KIBERone: что делает, чем отвечает, как адаптируется новичок, KPI и метрики.
      </p>
    </div>
  </section>

  <section class="container-page py-12 space-y-12">
    {departments.map((dept) => (
      <div>
        <h2 class="font-display text-xl md:text-2xl font-bold text-kiber-dark mb-4">{dept}</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {grouped[dept].map((p) => (
            <a href={`/positions/${p.slug}/`} class="card p-5 hover:-translate-y-0.5 transition flex flex-col">
              <div class="flex items-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-kiber-dark/5 grid place-items-center text-xl">{p.icon}</div>
                <div>
                  <div class="font-semibold text-kiber-dark">{p.title}</div>
                  <div class="text-xs text-kiber-muted">{p.group === 'central' ? 'центральная роль' : 'роль в филиале'}</div>
                </div>
              </div>
              <p class="mt-3 text-sm text-kiber-ink/80 flex-1">{p.short}</p>
              <span class="mt-3 text-sm font-semibold text-kiber-blue">Открыть →</span>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>
</BaseLayout>
